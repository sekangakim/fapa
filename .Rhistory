print(p_inertia)
## ----------------------------------------------------------------
## 4)  Dimension classification — HARD-CODED
##
##     diff_dims = c(1, 3)  — verified against the manuscript biplot
##     sum_dims  = c(2, 4)  — verified against the manuscript biplot
##
##     TCC (Section 5) CONFIRMS this classification but does NOT
##     determine it.  Hard-coding protects against any numerical
##     artefact in automatic classification procedures.
## ----------------------------------------------------------------
diff_dims <- c(1L, 3L)
sum_dims  <- c(2L, 4L)
plane     <- diff_dims         ## biplot plane for difference
sum_pair  <- sum_dims          ## biplot plane for sum
cat("\n--- Section 4: Dimension Classification ---\n")
cat(sprintf("  diff_dims = c(1,3)  (%.1f%% + %.1f%% = %.1f%% inertia)\n",
perc10[1], perc10[3], perc10[1]+perc10[3]))
cat(sprintf("  sum_dims  = c(2,4)  (%.1f%% + %.1f%% = %.1f%% inertia)\n",
perc10[2], perc10[4], perc10[2]+perc10[4]))
## ----------------------------------------------------------------
## 5)  Tucker's Congruence Coefficients — VALIDATION ONLY
##
##     Manual SVD of Z bypasses ca-package sign normalization.
##     Column coordinate pairs (left vs right block) satisfy
##     TCC = ±1 exactly by the circulant theorem:
##       diff dims => TCC near -1  (opposite directions)
##       sum  dims => TCC near +1  (same directions)
##
##     TCC is computed for EXACTLY the four biplot dimensions
##     c(1, 2, 3, 4) — the dimensions used in the manuscript
##     figures — regardless of permutation significance.
##     Threshold |TCC| >= .95 required for confirmation.
## ----------------------------------------------------------------
cat("\n--- Section 5: Tucker's Congruence Coefficients ---\n")
P_mat  <- C10 / sum(C10)
r_mass <- rowSums(P_mat)
c_mass <- colSums(P_mat)
Z_man  <- diag(1/sqrt(r_mass)) %*%
(P_mat - outer(r_mass, c_mass)) %*%
diag(1/sqrt(c_mass))
svd_z  <- svd(Z_man)
n_svd  <- length(svd_z$d) - 1L
Gamma_raw <- diag(1/sqrt(c_mass)) %*% svd_z$v[, seq_len(n_svd)]
GL <- Gamma_raw[ix$left_cols,  ]
GR <- Gamma_raw[ix$right_cols, ]
## Compute TCC for exactly the four biplot dimensions (1, 2, 3, 4)
biplot_dims <- c(1L, 2L, 3L, 4L)
tcc_vals <- sapply(biplot_dims, function(k) {
gl <- GL[,k]; gr <- GR[,k]
nl <- sqrt(sum(gl^2)); nr <- sqrt(sum(gr^2))
if (nl < 1e-12 || nr < 1e-12) return(NA_real_)
as.numeric(t(gl) %*% gr) / (nl * nr)
})
names(tcc_vals) <- paste0("Dim", biplot_dims)
dim_type_label <- ifelse(biplot_dims %in% diff_dims, "Difference", "Sum")
tcc_table <- data.frame(
Dimension  = paste0("Dim ", biplot_dims),
Type       = dim_type_label,
TCC        = round(tcc_vals, 6),
Expected   = ifelse(dim_type_label=="Difference", "< -0.95", "> +0.95"),
Confirmed  = ifelse(
(dim_type_label=="Difference" & tcc_vals < -.95) |
(dim_type_label=="Sum"        & tcc_vals >  .95),
"YES", "NO"),
stringsAsFactors = FALSE
)
cat("\nTCC Table — four biplot dimensions (Dims 1, 2, 3, 4):\n")
cat("(Red bars = Difference dims 1 & 3;  Blue bars = Sum dims 2 & 4)\n")
print(tcc_table, row.names=FALSE)
if (any(tcc_table$Confirmed == "NO"))
warning("One or more TCC values do not confirm the classification at |TCC|>=.95.")
## TCC bar chart — four biplot dimensions only
## Enforce display order: Dim 1, Dim 2, Dim 3, Dim 4
tcc_table$Dimension <- factor(tcc_table$Dimension,
levels = paste0("Dim ", biplot_dims))
p_tcc <- ggplot(tcc_table, aes(x=Dimension, y=TCC, fill=Type)) +
geom_bar(stat="identity", color="black", width=.6) +
geom_hline(yintercept= .95, linetype="dashed",
color="darkgreen", linewidth=.7) +
geom_hline(yintercept=-.95, linetype="dashed",
color="darkred",  linewidth=.7) +
geom_hline(yintercept= 0,   color="black", linewidth=.4) +
scale_fill_manual(values=c("Difference"="#D73027","Sum"="#4575B4")) +
scale_y_continuous(limits=c(-1,1), breaks=seq(-1,1,.25)) +
labs(title    = "Tucker's Congruence Coefficients by Dimension",
subtitle = paste0("Dims 1 & 3 (red) = difference dimensions;  ",
"Dims 2 & 4 (blue) = sum dimensions\n",
"Dashed lines: |TCC| = .95 confirmation threshold"),
x        = "Dimension",
y        = expression(paste("Tucker's ",psi[k])),
fill     = "Dimension Type") +
theme_bw(base_size=11) + theme(legend.position="bottom")
print(p_tcc)
## ----------------------------------------------------------------
## 6)  Procrustes principal angles — external subspace validation
## ----------------------------------------------------------------
cat("\n--- Section 6: Procrustes Principal Angles ---\n")
ca_F <- ca::ca(F_mat); ca_M <- ca::ca(M_mat)
cF   <- as.matrix(ca_F$rowcoord[, 1:2])
cM   <- as.matrix(ca_M$rowcoord[, 1:2])
svd_P       <- svd(t(cF) %*% cM)
T_proc      <- svd_P$v %*% t(svd_P$u)
cM_rot      <- cM %*% T_proc
proc_ss     <- sum((cF - cM_rot)^2)
cos_pa    <- pmin(pmax(svd(t(qr.Q(qr(cF))) %*% qr.Q(qr(cM_rot)))$d, 0), 1)
theta_deg <- acos(cos_pa) * 180 / pi
interp_angle <- function(deg)
dplyr::case_when(
deg < 30 ~ "Near-identical subspaces",
deg < 60 ~ "Moderate divergence",
deg < 80 ~ "Substantial divergence",
TRUE     ~ "Near-orthogonal subspaces"
)
pa_table <- data.frame(
Angle          = paste0("theta_", seq_along(theta_deg)),
Cosine         = round(cos_pa, 4),
Degrees        = round(theta_deg, 2),
Interpretation = interp_angle(theta_deg),
stringsAsFactors = FALSE
)
cat("\nProcrustes Principal Angles (2D subspaces: F vs M):\n")
print(pa_table, row.names=FALSE)
cat(sprintf("Procrustes SS: %.4f\n", proc_ss))
cat("\n--- Interpretation of Principal Angles ---\n")
cat(sprintf(
"theta1 = %.1f deg and theta2 = %.1f deg indicate that the
female and male 2D CA subspaces are geometrically similar in
orientation after Procrustes alignment.
This result carries two important implications:
(1) COMMENSURABILITY CONFIRMED: Small principal angles confirm
that both groups are measured on a structurally compatible
categorical scale — the age-by-symptom spaces of females
and males span nearly the same geometric directions.
This is a necessary prerequisite for matched CA: the method
requires that group-specific tables be commensurable so that
their concatenation is meaningful.
(2) NOT A CONTRADICTION OF GROUP DIFFERENCES: Small subspace
angles do not imply that groups are identical. They indicate
that the OVERALL 2D dimensional structure is aligned.
Matched CA operates within this shared frame to isolate
the specific CONTRAST patterns — encoded in difference
dimensions 1 and 3 (68.5%% of total inertia) — that
distinguish female from male profiles. The magnitude and
direction of differences within the shared subspace are
what the difference biplot and cosine measures capture.
Analogy: two orchestras may tune to the same scale (small
angle = same tonal space) yet play entirely different
compositions (large difference inertia = distinct patterns).
Conclusion: theta1 = %.1f deg and theta2 = %.1f deg confirm
that matched CA is applied to commensurable groups, while the
68.5%% difference inertia in Dims 1 & 3 reveals the substantial
contrast structure that exists within that shared space.\n",
theta_deg[1], theta_deg[2], theta_deg[1], theta_deg[2]
))
## Subspace plot — updated subtitle with interpretation
pa_df <- rbind(
data.frame(x=cF[,1],     y=cF[,2],
Group="Female",
Label=rownames(F_mat)),
data.frame(x=cM_rot[,1], y=cM_rot[,2],
Group="Male (Procrustes-rotated)",
Label=rownames(M_mat))
)
seg_df <- data.frame(
x    = cF[,1],     y    = cF[,2],
xend = cM_rot[,1], yend = cM_rot[,2]
)
p_pa <- ggplot(pa_df, aes(x=x,y=y,color=Group,label=Label)) +
geom_segment(data=seg_df, aes(x=x,y=y,xend=xend,yend=yend),
inherit.aes=FALSE, linetype="dashed",
color="gray60", linewidth=.5) +
geom_point(size=3) +
ggrepel::geom_text_repel(size=3.5, seed=42) +
scale_color_manual(values=c("Female"="#D73027",
"Male (Procrustes-rotated)"="#4575B4")) +
geom_hline(yintercept=0, linetype="dotted", color="gray70") +
geom_vline(xintercept=0, linetype="dotted", color="gray70") +
labs(
title    = "Female and Male CA Subspaces After Procrustes Rotation",
subtitle = sprintf(
paste0("theta1 = %.1f deg,  theta2 = %.1f deg  ",
"(both < 30 deg: subspaces are commensurable)\n",
"Small angles confirm matched CA prerequisite; ",
"contrast patterns are captured within this shared space"),
theta_deg[1], theta_deg[2]),
x = "CA Dimension 1",
y = "CA Dimension 2",
color = "Group"
) +
theme_bw(base_size=11) + theme(legend.position="bottom")
print(p_pa)
## ----------------------------------------------------------------
## 7)  Difference biplot — Dims 1 & 3
##     Blue dots = row principal coordinates (age groups)
##     Red arrows = enhanced column standard coordinates (symptoms)
## ----------------------------------------------------------------
cat("\n--- Section 7: Difference Biplot (Dims 1 & 3) ---\n")
pfmt <- function(x) sprintf("%.1f%%", x)
pad  <- function(z) diff(range(z)) * 0.08
rows_df <- data.frame(
x=R_princ[ix$f_rows,    plane[1]],
y=R_princ[ix$f_rows,    plane[2]],
label=rows_lab, stringsAsFactors=FALSE)
cols_df <- data.frame(
x=C_enhanced[ix$left_cols, plane[1]],
y=C_enhanced[ix$left_cols, plane[2]],
label=cols_lab, stringsAsFactors=FALSE)
xr   <- range(c(rows_df$x, cols_df$x))
yr   <- range(c(rows_df$y, cols_df$y))
xlim <- c(xr[1]-pad(xr), xr[2]+pad(xr))
ylim <- c(yr[1]-pad(yr), yr[2]+pad(yr))
p_diff <- ggplot() +
