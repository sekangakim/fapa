## ----------------------------------------------------------------
## 9)  BCa 95% CIs for biplot coordinates
##
##     Individual-level stratified nonparametric bootstrap.
##     Statistic returns 20-element vector:
##       indices 1-5:   F row Dim1 coords
##       indices 6-10:  F row Dim3 coords
##       indices 11-15: Symptom Dim1 coords (enhanced std)
##       indices 16-20: Symptom Dim3 coords (enhanced std)
##     boot::boot.ci(type="bca") used directly.
## ----------------------------------------------------------------
cat("\n--- Section 9: BCa CIs for Biplot Coordinates ---\n")
## Procrustes alignment helper
procrustes_to <- function(Rp, Cp, R0, C0) {
S  <- t(as.matrix(Cp)) %*% as.matrix(C0)
sv <- svd(S)
Q  <- sv$u %*% t(sv$v)
list(R = as.matrix(Rp) %*% Q,
C = as.matrix(Cp) %*% Q)
}
## Reference solution
R0_ref <- R_princ[,    plane, drop=FALSE]
C0_ref <- C_enhanced[, plane, drop=FALSE]
n_F <- nrow(ind_F);  n_M <- nrow(ind_M)
all_ind    <- rbind(ind_F, ind_M)
strata_vec <- c(rep(1L, n_F), rep(2L, n_M))
stat_coords <- function(data, indices) {
idx_F <- indices[indices <= n_F]
idx_M <- indices[indices >  n_F]
if (length(idx_F) < 5 || length(idx_M) < 5)
return(rep(NA_real_, 20L))
Fp <- rebuild_table(data$age[idx_F], data$sym[idx_F],
5L, 5L, rownames(F_mat), colnames(F_mat))
Mp <- rebuild_table(data$age[idx_M], data$sym[idx_M],
5L, 5L, rownames(M_mat), colnames(M_mat))
if (any(rowSums(Fp)==0) || any(colSums(Fp)==0) ||
any(rowSums(Mp)==0) || any(colSums(Mp)==0))
return(rep(NA_real_, 20L))
C10b <- build_FMMF(Fp, Mp)
fb   <- try(ca::ca(C10b), silent=TRUE)
if (inherits(fb, "try-error")) return(rep(NA_real_, 20L))
kk <- ncol(fb$rowcoord)
if (kk < max(plane)) return(rep(NA_real_, 20L))
Rb <- sweep(fb$rowcoord, 2, fb$sv[seq_len(kk)], `*`)
cb <- colSums(C10b) / sum(C10b)
Cb <- sweep(fb$colcoord, 1, sqrt(cb), `*`)
Rp <- Rb[, plane, drop=FALSE]
Cp <- Cb[, plane, drop=FALSE]
if (any(!is.finite(Rp)) || any(!is.finite(Cp)))
return(rep(NA_real_, 20L))
AC <- try(procrustes_to(Rp, Cp, R0_ref, C0_ref), silent=TRUE)
if (inherits(AC, "try-error")) return(rep(NA_real_, 20L))
R_s <- AC$R[ix$f_rows,    , drop=FALSE]
C_s <- AC$C[ix$left_cols, , drop=FALSE]
c(as.vector(R_s), as.vector(C_s))
}
set.seed(2025)
B_coord <- 10000
cat(sprintf("Stratified nonparametric bootstrap (B = %d)...\n", B_coord))
bt_coord <- boot::boot(data=all_ind, statistic=stat_coords,
R=B_coord, strata=strata_vec)
## Set t0 from observed reference solution
bt_coord$t0 <- c(as.vector(R0_ref[ix$f_rows,    , drop=FALSE]),
as.vector(C0_ref[ix$left_cols, , drop=FALSE]))
n_ok_c <- sum(is.finite(bt_coord$t[,1]))
cat(sprintf("Usable resamples: %d / %d\n", n_ok_c, B_coord))
if (n_ok_c < B_coord * 0.8)
warning("Fewer than 80% coordinate resamples usable.")
## BCa CIs via boot::boot.ci
get_bca <- function(j, bt) {
if (!is.finite(bt$t0[j])) return(c(NA_real_, NA_real_))
if (sum(is.finite(bt$t[,j])) < 100) return(c(NA_real_, NA_real_))
ci <- try(boot::boot.ci(bt, type="bca", index=j), silent=TRUE)
if (inherits(ci,"try-error") || is.null(ci$bca))
return(c(NA_real_, NA_real_))
c(ci$bca[4], ci$bca[5])
}
## Assemble coordinate CI table
## Flat vector layout: rows Dim1 (1-5), rows Dim3 (6-10),
##                     cols Dim1 (11-15), cols Dim3 (16-20)
coord_entries <- list()
for (i in seq_along(rows_lab)) {
for (d in 1:2) {
j  <- (d-1)*5 + i
ci <- get_bca(j, bt_coord)
coord_entries[[length(coord_entries)+1]] <- data.frame(
Type=  "Row", Label=rows_lab[i], Dim=paste0("Dim",plane[d]),
Est=   round(bt_coord$t0[j],3),
BCa_lo=round(ci[1],3), BCa_hi=round(ci[2],3),
Zero_excl=!is.na(ci[1])&!is.na(ci[2])&
((ci[1]>0&ci[2]>0)|(ci[1]<0&ci[2]<0))
)
}
}
for (i in seq_along(cols_lab)) {
for (d in 1:2) {
j  <- 10 + (d-1)*5 + i
ci <- get_bca(j, bt_coord)
coord_entries[[length(coord_entries)+1]] <- data.frame(
Type=  "Col", Label=cols_lab[i], Dim=paste0("Dim",plane[d]),
Est=   round(bt_coord$t0[j],3),
BCa_lo=round(ci[1],3), BCa_hi=round(ci[2],3),
Zero_excl=!is.na(ci[1])&!is.na(ci[2])&
((ci[1]>0&ci[2]>0)|(ci[1]<0&ci[2]<0))
)
}
}
bca_coords <- do.call(rbind, coord_entries)
cat("\nBCa 95% CIs for Biplot Coordinates:\n")
print(bca_coords, row.names=FALSE)
## ----------------------------------------------------------------
## 10)  BCa 95% CIs for cosine-based association measures
##      Same bootstrap framework; 25-element cosine vector.
## ----------------------------------------------------------------
cat("\n--- Section 10: BCa CIs for Cosine Associations ---\n")
cosine_rc <- function(Rmat, Cmat) {
Rmat <- as.matrix(Rmat); Cmat <- as.matrix(Cmat)
rn   <- sqrt(rowSums(Rmat^2)); cn <- sqrt(rowSums(Cmat^2))
rn[rn==0] <- NA_real_;         cn[cn==0] <- NA_real_
(Rmat %*% t(Cmat)) / outer(rn, cn)
}
cos_obs <- cosine_rc(R0_ref[ix$f_rows,    , drop=FALSE],
C0_ref[ix$left_cols, , drop=FALSE])
cat("Observed cosine matrix:\n"); print(round(cos_obs,3))
stat_cos <- function(data, indices) {
idx_F <- indices[indices <= n_F]
idx_M <- indices[indices >  n_F]
if (length(idx_F) < 5 || length(idx_M) < 5)
return(rep(NA_real_, 25L))
Fp <- rebuild_table(data$age[idx_F], data$sym[idx_F],
5L, 5L, rownames(F_mat), colnames(F_mat))
Mp <- rebuild_table(data$age[idx_M], data$sym[idx_M],
5L, 5L, rownames(M_mat), colnames(M_mat))
if (any(rowSums(Fp)==0)||any(colSums(Fp)==0)||
any(rowSums(Mp)==0)||any(colSums(Mp)==0))
return(rep(NA_real_, 25L))
C10b <- build_FMMF(Fp, Mp)
fb   <- try(ca::ca(C10b), silent=TRUE)
if (inherits(fb,"try-error")) return(rep(NA_real_, 25L))
kk <- ncol(fb$rowcoord)
if (kk < max(plane)) return(rep(NA_real_, 25L))
Rb <- sweep(fb$rowcoord, 2, fb$sv[seq_len(kk)], `*`)
cb <- colSums(C10b) / sum(C10b)
Cb <- sweep(fb$colcoord, 1, sqrt(cb), `*`)
Rp <- Rb[,plane,drop=FALSE]; Cp <- Cb[,plane,drop=FALSE]
if (any(!is.finite(Rp))||any(!is.finite(Cp)))
return(rep(NA_real_, 25L))
AC <- try(procrustes_to(Rp, Cp, R0_ref, C0_ref), silent=TRUE)
if (inherits(AC,"try-error")) return(rep(NA_real_, 25L))
as.vector(cosine_rc(AC$R[ix$f_rows,,drop=FALSE],
AC$C[ix$left_cols,,drop=FALSE]))
}
set.seed(1)
B_cos <- 10000
cat(sprintf("Stratified nonparametric bootstrap (B = %d)...\n", B_cos))
bt_cos <- boot::boot(data=all_ind, statistic=stat_cos,
R=B_cos, strata=strata_vec)
bt_cos$t0 <- as.vector(cos_obs)
n_ok_cos <- sum(is.finite(bt_cos$t[,1]))
cat(sprintf("Usable resamples: %d / %d\n", n_ok_cos, B_cos))
if (n_ok_cos < B_cos * 0.8)
warning("Fewer than 80% cosine resamples usable.")
idx_grid <- expand.grid(row=rows_lab, col=cols_lab,
KEEP.OUT.ATTRS=FALSE, stringsAsFactors=FALSE)
cis_cos  <- t(sapply(seq_len(25L), get_bca, bt=bt_cos))
cos_bca <- data.frame(
row      = idx_grid$row,
col      = idx_grid$col,
cos_obs  = round(as.vector(cos_obs),3),
ci_lo    = round(cis_cos[,1],3),
ci_hi    = round(cis_cos[,2],3),
zero_excl= !is.na(cis_cos[,1])&!is.na(cis_cos[,2])&
((cis_cos[,1]>0&cis_cos[,2]>0)|
(cis_cos[,1]<0&cis_cos[,2]<0)),
stringsAsFactors=FALSE
)
cos_bca <- cos_bca[order(-abs(cos_bca$cos_obs)),]
rownames(cos_bca) <- NULL
cat("\nTop cosine associations with BCa 95% CIs:\n")
print(head(cos_bca, 15))
# write.csv(cos_bca, "cosine_BCa_CIs.csv", row.names=FALSE)
## ----------------------------------------------------------------
## 11)  Consolidated validation summary
## ----------------------------------------------------------------
cat("\n")
cat("=======================================================\n")
cat("  MATCHED CA — THREE-STAGE VALIDATION SUMMARY\n")
cat("=======================================================\n\n")
cat("Stage 1 | Parallel Analysis — Group-Shuffle Permutation (B =", B_perm, ")\n")
cat(sprintf("  PA criterion (observed > Sim. 99%%): Dims %s retained (n = %d)\n",
paste(retained_D, collapse=", "), n_retained_D))
cat(sprintf("  Retained dims account for %.1f%% of total inertia\n",
sum(perc10[retained_D])))
cat(sprintf("  Difference biplot Dims 1 & 3: %.1f%% + %.1f%% = %.1f%% inertia\n",
perc10[1], perc10[3], perc10[1]+perc10[3]))
cat(sprintf("  Sum biplot       Dims 2 & 4: %.1f%% + %.1f%% = %.1f%% inertia\n\n",
perc10[2], perc10[4], perc10[2]+perc10[4]))
cat("Stage 2 | Dimension Classification + TCC Confirmation\n")
cat("  diff_dims = c(1,3)  [hard-coded; TCC-confirmed]\n")
cat("  sum_dims  = c(2,4)  [hard-coded; TCC-confirmed]\n")
for (i in seq_along(biplot_dims))
cat(sprintf("    Dim %d (%s): TCC = %+.6f  [Confirmed: %s]\n",
biplot_dims[i],
ifelse(biplot_dims[i] %in% diff_dims,"Difference","Sum"),
tcc_vals[i], tcc_table$Confirmed[i]))
cat(sprintf("  Inertia Dims 1&3: %.1f%%\n", sum(perc10[diff_dims])))
cat(sprintf("  Inertia Dims 2&4: %.1f%%\n\n", sum(perc10[sum_dims])))
cat("Stage 3 | Procrustes Principal Angles\n")
for (i in seq_along(theta_deg))
cat(sprintf("  theta_%d = %.2f deg  [%s]\n",
i, theta_deg[i], interp_angle(theta_deg[i])))
cat("\n=======================================================\n")
cat("  Biplots: Dims 1 & 3 (difference) | Dims 2 & 4 (sum)\n")
cat("=======================================================\n")
