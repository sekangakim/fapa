color="blue", size=3.3, seed=1) +
ggrepel::geom_text_repel(data=cols_df, aes(x=x,y=y,label=label),
color="red", fontface="bold", size=3.3, seed=1) +
geom_hline(yintercept=0, linewidth=.3, linetype="dotted") +
geom_vline(xintercept=0, linewidth=.3, linetype="dotted") +
coord_cartesian(xlim=xlim, ylim=ylim, expand=TRUE) +
labs(
title    = paste0("Sex-Difference Biplot (Dims ",
paste(plane,collapse=" & "),")"),
subtitle = paste0("Row-principal (Ages) & Column-enhanced-standard",
" (Symptoms); plane total = ",
pfmt(sum(perc10[plane]))),
x = paste0("Difference Dim ",plane[1]," (",pfmt(perc10[plane[1]]),")"),
y = paste0("Difference Dim ",plane[2]," (",pfmt(perc10[plane[2]]),")")
) +
theme_minimal(base_size=11) +
theme(legend.position="none", plot.title=element_text(face="bold"))
print(p_diff)
## ----------------------------------------------------------------
